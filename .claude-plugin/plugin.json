{
  "name": "olympus",
  "version": "2.0.3",
  "description": "Olympus — Harness engineering plugin. 15 agents perform requirement refinement, multi-perspective analysis, evolution loops, and evaluation.",
  "license": "MIT",
  "author": {
    "name": "hjyoon"
  },
  "repository": "https://github.com/devy1540/olympus",
  "mcpServers": {
    "olympus-pipeline": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-mcp.sh",
      "args": [
        "serve"
      ],
      "env": {
        "OLYMPUS_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "OLYMPUS_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
